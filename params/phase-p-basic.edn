;; Phase P: Basic Bribery Test
;; Baseline from Phase I but with bribery cost model enabled
;; Expected: Malice should drop from +14 to closer to 0 or negative

{:escrow-size 10000
 :resolver-fee-bps 100
 :appeal-bond-bps 200
 :slash-multiplier 2
 :strategy :malicious
 :appeal-probability-if-correct 0.1
 :appeal-probability-if-wrong 0.5
 :slashing-detection-probability 0.25

 ; Phase H: Fraud detection + slashing
 :fraud-detection-probability 0.25
 :fraud-slash-bps 500

 ; Phase P: Bribery cost model
 ; bribe-cost-ratio: How much margin on top of base cost (1.3 = 30% premium)
 ; This is calibrated to match Kleros jury behavior
 :bribe-cost-ratio 1.3

 ; Optional: Can track attacker budget
 ; :attacker-budget 5000
}

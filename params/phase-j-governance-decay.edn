{:scenario-id "phase-j-governance-decay"
 :description "Phase J Gap #2: Governance failure scenario. Detection rate decays by 50% per epoch (halving). Tests system robustness as fraud detection capability deteriorates."
 :rng-seed 42
 
 :escrow-distribution
 {:type :lognormal
  :mean 10000
  :std 5000}
 
 :strategy-mix
 {:honest 0.50
  :lazy 0.15
  :malicious 0.25
  :collusive 0.10}
 
 :resolver-fee-bps 150
 :appeal-bond-bps 700
 :slash-multiplier 2.5
 :appeal-probability-if-correct 0.05
 :appeal-probability-if-wrong 0.40
 
 ; Phase I: Three detection mechanisms
 :slashing-detection-probability 0.10
 :fraud-detection-probability 0.25
 :fraud-slash-bps 5000
 :reversal-detection-probability 0.25
 :reversal-slash-bps 2500
 :timeout-slash-bps 200
 
 ; Phase H: Realistic bond mechanics
 :unstaking-delay-days 14
 :freeze-on-detection? true
 :freeze-duration-days 3
 :appeal-window-days 7
 
 ; Phase J: Multi-epoch with governance decay
 :n-epochs 10
 :n-trials-per-epoch 500
 :n-resolvers 100
 :detection-decay-rate 0.5  ; Detection halves each epoch (critical assumption)
 :n-seeds 1}

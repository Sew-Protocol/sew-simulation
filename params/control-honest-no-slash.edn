{:description "Control baseline: Honest resolvers never slashed (theoretical upper bound)"
 :scenario-id "control-honest-no-slash"
 :rng-seed 42

 ;; Escrow sizes (same as baseline)
 :escrow-distribution
 {:type :lognormal
  :mean 10000
  :stddev 5000}

 ;; Only honest resolvers (force strategy)
 :force-strategy :honest
 :strategy-mix
 {:honest 1.0
  :lazy 0.0
  :malicious 0.0
  :collusive 0.0}

 ;; No slashing possible (control condition)
 :allow-slashing? false

 ;; Economic parameters (same as baseline)
 :resolver-fee-bps 150          ; 1.5%
 :appeal-bond-bps 700           ; 7%
 :slash-multiplier 2.5

 ;; Appeal dynamics (high detection to make clear they never slash)
 :appeal-probability-if-correct 0.05
 :appeal-probability-if-wrong 0.40
 :slashing-detection-probability 0.99  ; Even if somehow detected, no slashing

 ;; Simulation config
 :n-trials 1000
 :n-seeds 1
 :parallelism :auto
 :save-samples? false
 :save-sweep? false}

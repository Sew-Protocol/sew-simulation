{:description "DR2: Reputation + Bond + Slashing (no progressive slashing)"
 :scenario-id "dr2-reputation"
 :rng-seed 42

 ;; Escrow sizes (wei, log scale)
 :escrow-distribution
 {:type :lognormal
  :mean 10000
  :stddev 5000}

 ;; Resolver strategy mix
 :strategy-mix
 {:honest 0.75
  :lazy 0.15
  :malicious 0.08
  :collusive 0.02}

 ;; Phase DR2: Reputation-weighted voting with bonds
 :phase :dr2

 ;; DR2: Bond + fee model - resolvers stake 5% bond, earn 1.5% fee
 :resolver-fee-bps 150          ; 1.5% fee
 :appeal-bond-bps 700           ; 7% appeal bond (user pays)
 :resolver-bond-bps 500         ; 5% resolver bond (resolver stakes)
 :slash-multiplier 1.5          ; 1.5× slash multiplier (DR2 vs DR3's 2.5×)
 :allow-slashing? true           ; Enable slashing

 ;; DR2: Reputation affects voting weight
 ;; Higher reputation = more voting power (quadratic: weight = rep^2)
 :reputation-enabled? true
 :reputation-initial 500         ; 50% (neutral start)
 :reputation-decay-bps-per-month 100  ; 1% per month decay

 ;; DR2: Single appeal allowed
 :appeal-probability-if-correct 0.05
 :appeal-probability-if-wrong 0.40
 :slashing-detection-probability 0.10

 ;; DR2: No L2 backstop yet (comes in DR3)
 :l2-detection-prob 0

 ;; DR2: Freeze mechanics for slashing
 :freeze-on-detection? true
 :freeze-duration-days 3
 :appeal-window-days 7

 ;; DR2: No progressive slashing (comes in DR3)
 :progressive-slashing? false

 ;; Simulation config
 :n-trials 10000
 :n-seeds 50
 :parallelism :auto

 ;; Output
 :save-samples? true
 :save-sweep? false}

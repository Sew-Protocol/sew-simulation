## Cartesi SEW environment template
# Copy to .env (or inject through your orchestrator/CI secrets) and set values per environment.

# Environment profile: dev | staging | prod
APP_ENV=dev

# Rollups endpoint used by rollup-init/java process
ROLLUP_HTTP_SERVER_URL=http://127.0.0.1:5004

# Verification-suite sender config
RPC_URL=http://127.0.0.1:8545
DAPP_ADDRESS=0xab7528bb862fB57E8A2BCd567a2e929a0Be56a5e
INPUT_BOX_ADDRESS=0x59b22D57D4f067708AB0c00552767405926dc768

# DO NOT commit real secrets. Use secret manager values in staging/prod.
PRIVATE_KEY=REPLACE_WITH_SECURE_INJECTED_KEY

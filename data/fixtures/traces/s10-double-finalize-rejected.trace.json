    "double-settlement"
  ],
  "scenario-id": "s10-double-finalize-rejected",
  "initial-block-time": 1000,
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "type": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "type": "honest"
    },
    {
      "id": "seller2",
      "address": "0xseller2",
      "type": "honest"
    },
    {
      "id": "resolver",
      "address": "0xresolver",
      "type": "resolver"
    }
  ],
  "protocol-params": {
    "resolver-fee-bps": 150,
    "appeal-window-duration": 0,
    "max-dispute-duration": 2592000

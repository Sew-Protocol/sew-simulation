{
  "schema-version": "1.1",
  "id": "scenarios/spe-reg-v8-profile-matrix",
  "scenario-id": "spe-reg-v8-profile-matrix",
  "title": "SPE Regression — profile-matrix reveals that any non-zero reputation penalty deters malicious verdict",
  "description": "Resolver registers stake (3000), creates escrow, buyer raises dispute, resolver gives malicious verdict (execute_resolution — proper-subgame node; pre-wealth≈3000). Resolver tops up stake post-verdict (+1000). Governance proposes and executes fraud slash (500), leaving terminal resolver-stakes=3500. resolver-reputation-profile-matrix runs three profiles: :reputation/none (penalty=0 → no regret → PASS, attacker indifferent), :reputation/conservative (penalty=25 at 0.5 discount → adj≈-13 → chosen-utility < best-alt-utility → FAIL), :reputation/baseline (penalty=100 at 0.8 discount → adj=-80 → FAIL). Demonstrates that deterrence activates at any non-zero reputation value; the profile matrix exposes this threshold explicitly.",
  "purpose": "theory-falsification",
  "threat-tags": ["resolver-slash", "reputation-gap", "profile-matrix"],

  "protocol-params": {
    "appeal-window-duration": 120,
    "fee-bps": 150
  },

  "initial-block-time": 1000,

  "agents": [
    {"id": "buyer",      "address": "0xbuyer",      "role": "buyer",      "strategy": "honest"},
    {"id": "seller",     "address": "0xseller",     "role": "seller",     "strategy": "honest"},
    {"id": "resolver",   "address": "0xresolver",   "role": "resolver",   "strategy": "malicious"},
    {"id": "keeper",     "address": "0xkeeper",     "role": "keeper",     "strategy": "honest"},
    {"id": "governance", "address": "0xgovernance", "role": "governance", "strategy": "honest"}
  ],

  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "resolver",
      "action": "register_stake",
      "params": {"amount": 3000}
    },
    {
      "seq": 1,
      "time": 1010,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 2000,
        "custom-resolver": "0xresolver"
      },
      "save-id-as": "wf0"
    },
    {
      "seq": 2,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {"workflow-id": "wf0"}
    },
    {
      "seq": 3,
      "time": 1120,
      "agent": "resolver",
      "action": "execute_resolution",
      "params": {
        "workflow-id": "wf0",
        "is-release": true,
        "resolution-hash": "0xhash"
      }
    },
    {
      "seq": 4,
      "time": 1125,
      "agent": "resolver",
      "action": "register_stake",
      "params": {"amount": 1000}
    },
    {
      "seq": 5,
      "time": 1130,
      "agent": "governance",
      "action": "propose_fraud_slash",
      "params": {
        "workflow-id": "wf0",
        "resolver-addr": "0xresolver",
        "amount": 500
      }
    },
    {
      "seq": 6,
      "time": 1241,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {"workflow-id": "wf0"}
    },
    {
      "seq": 7,
      "time": 1260,
      "agent": "governance",
      "action": "execute_fraud_slash",
      "params": {"workflow-id": "wf0"}
    }
  ],

  "theory": {
    "claim-id": "claims/spe-reg-profile-matrix",
    "claim": "Running resolver-reputation-profile-matrix against three assumption profiles on the same malicious-verdict trace shows that reputation deterrence is absent under :reputation/none (attacker indifferent, regret=0) but present under both :reputation/conservative and :reputation/baseline (any non-zero penalty creates regret because best-alt-utility=terminal-realized while chosen-utility includes rep-adj). The minimum reputation penalty required for deterrence is strictly positive and computable from the profile results.",
    "equilibrium-concept": [
      "resolver-reputation-profile-matrix"
    ],
    "spe-config": {
      "regret-threshold": 0,
      "epsilon-abs": 0.0,
      "epsilon-rel": 0.0,
      "utility-profiles": [
        "reputation/none",
        "reputation/conservative",
        "reputation/baseline"
      ],
      "utility-spec": {
        "type": "resolver-reputation-v1",
        "slash-detection-mode": "explicit-slash-total",
        "slash-threshold": 1,
        "reputation-slash-penalty": 0,
        "reputation-discount-rate": 1.0
      }
    },
    "falsifies-if": [],
    "assumptions": [
      "reputation-deters-at-any-positive-penalty",
      "forward-pass-best-alt-uses-local-snapshot",
      "slash-detected-via-resolver-slash-total",
      "single-trace-proxy"
    ]
  },

  "expectations": {
    "terminal": [
      {
        "path": ["live-states", 0],
        "equals": "released"
      }
    ],
    "metrics": [
      {
        "name": "total-escrows",
        "op": ":=",
        "value": 1
      }
    ]
  }
}

{
  "schema-version": "1.1",
  "id": "scenarios/s65-escalation-supersedes-old-pending-then-old-path-attempt",
  "title": "Escalation Supersedes Old Pending Then Old Path Attempt",
  "purpose": "regression",
  "threat-tags": [
    "pending-lifecycle",
    "escalation-supersession"
  ],
  "scenario-id": "s65-escalation-supersedes-old-pending-then-old-path-attempt",
  "allow-open-disputes?": true,
  "initial-block-time": 1000,
  "agents": [
    {"id": "buyer", "address": "0xbuyer", "type": "honest"},
    {"id": "seller", "address": "0xseller", "type": "honest"},
    {"id": "resolver0", "address": "0xresolver0", "type": "resolver"},
    {"id": "resolver1", "address": "0xresolver1", "type": "resolver"},
    {"id": "keeper", "address": "0xkeeper", "type": "resolver"}
  ],
  "protocol-params": {
    "resolver-fee-bps": 0,
    "appeal-window-duration": 120,
    "max-dispute-duration": 600,
    "dispute-resolver": "0xresolver0",
    "escalation-resolvers": {"1": "0xresolver1"},
    "max-escalation-level": 1
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {"token": "USDC", "to": "0xseller", "amount": 4200, "custom-resolver": "0xresolver0"},
      "save-id-as": "wf0"
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "raise_dispute",
      "params": {"workflow-id": "wf0"}
    },
    {
      "seq": 2,
      "time": 1120,
      "agent": "resolver0",
      "action": "execute_resolution",
      "params": {"workflow-id": "wf0", "is-release": true, "resolution-hash": "0xl0hash"}
    },
    {
      "seq": 3,
      "time": 1160,
      "agent": "seller",
      "action": "escalate_dispute",
      "params": {"workflow-id": "wf0"}
    },
    {
      "seq": 4,
      "time": 1180,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {"workflow-id": "wf0"}
    },
    {
      "seq": 5,
      "time": 1240,
      "agent": "resolver1",
      "action": "execute_resolution",
      "params": {"workflow-id": "wf0", "is-release": false, "resolution-hash": "0xl1hash"}
    },
    {
      "seq": 6,
      "time": 1365,
      "agent": "keeper",
      "action": "execute_pending_settlement",
      "params": {"workflow-id": "wf0"}
    }
  ]
}
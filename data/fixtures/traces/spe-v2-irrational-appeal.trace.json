  "initial-block-time": 1000,
  "agents": [
    { "id": "buyer", "address": "0xbuyer", "type": "honest" },
    { "id": "seller", "address": "0xseller", "type": "honest" },
    { "id": "l0", "address": "0xl0", "type": "resolver" },
    { "id": "l1", "address": "0xl1", "type": "resolver" },
    { "id": "keeper", "address": "0xkeeper", "type": "keeper" }
  ],
  "protocol-params": {
    "resolver-fee-bps": 100,
    "resolution-module": "0xkleros-proxy",
    "escalation-resolvers": { "0": "0xl0", "1": "0xl1" },
    "appeal-window-duration": 3600,
    "appeal-bond-amount": 500,
    "max-dispute-duration": 2592000
  },
  "theory": {
    "claim-id": "claims/spe-irrational",
    "claim": "Irrational appeal is NOT SPE-consistent.",
    "equilibrium-concept": ["subgame-perfect-equilibrium"],
    "assumptions": [],
    "falsifies-if": []
  },
  "events": [
    { "seq": 0, "time": 1000, "agent": "buyer", "action": "create_escrow", "params": { "token": "USDC", "to": "0xseller", "amount": 5000 }, "save-id-as": "wf0" },
    { "seq": 1, "time": 1100, "agent": "buyer", "action": "raise_dispute", "params": { "workflow-id": "wf0" } },
    { "seq": 2, "time": 1200, "agent": "l0", "action": "execute_resolution", "params": { "workflow-id": "wf0", "is-release": true, "resolution-hash": "0x0" } },
    { "seq": 3, "time": 1300, "agent": "buyer", "action": "escalate_dispute", "params": { "workflow-id": "wf0" } },
    { "seq": 4, "time": 1400, "agent": "l1", "action": "execute_resolution", "params": { "workflow-id": "wf0", "is-release": true, "resolution-hash": "0x1" } },
    { "seq": 5, "time": 86400, "agent": "keeper", "action": "execute_pending_settlement", "params": { "workflow-id": "wf0" } }
  ]

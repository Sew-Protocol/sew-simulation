{
  "schema-version": "1.1",
  "id": "scenarios/spe-v2-irrational-appeal",
  "scenario-id": "spe-v2-irrational-appeal",
  "title": "SPE: Irrational Appeal",
  "description": "Buyer loses L0, escalates and loses L1. Terminal wealth < wealth before escalation.",
  "purpose": "adversarial-robustness",

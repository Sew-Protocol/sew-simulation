{
  "id": "scenarios/s01-baseline-happy-path",
  "scenario-id": "s01-baseline-happy-path",
  "title": "Baseline Successful Release",
  "description": "Standard escrow creation followed by buyer release.",
  "purpose": "regression",
  "schema-version": "1.1",
  "initial-block-time": 1000,
  "threat-tags": [],
  "agents": [
    { "id": "buyer", "address": "0xbuyer", "role": "buyer", "strategy": "honest" },
    { "id": "seller", "address": "0xseller", "role": "seller", "strategy": "honest" }
  ],
  "theory": {
    "claim-id": "claims/honest-release-works",
    "claim": "Honest buyers can successfully release funds to sellers.",
    "assumptions": ["Mempool is fair", "Token is standard ERC20"],
    "falsifies-if": [
      { "metric": "reverts", "op": ">", "value": 0 }
    ]
  },
  "expectations": {
    "terminal": [
      { "path": ["live-states", 0], "equals": "released" }
    ],
    "metrics": [
      { "name": "total-escrows", "op": ":=", "value": 1 }
    ]
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": { "token": "USDC", "to": "0xseller", "amount": 5000 },
      "save-wf-as": "wf0"
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "release",
      "params": { "workflow-id": "wf0" }
    }
  ]
}

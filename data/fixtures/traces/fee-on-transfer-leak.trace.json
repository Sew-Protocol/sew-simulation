{
  "schema-version": "1.1",
  "id": "scenarios/fee-on-transfer-leak",
  "title": "Fee-on-Transfer Token Accounting",
  "purpose": "adversarial-robustness",
  "threat-tags": [
    "token-accounting"
  ],
  "scenario-id": "fee-on-transfer-leak",
  "initial-block-time": 1000,
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "type": "honest"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "type": "honest"
    }
  ],
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "FOT-TOKEN",
        "to": "0xseller",
        "amount": 10000
      },
      "save-wf-as": "wf0"
    },
    {
      "seq": 1,
      "time": 1100,
      "agent": "buyer",
      "action": "release",
      "params": {
        "workflow-id": "wf0"
      }
    }
  ],
  "token-params": {
    "fee-on-transfer": 500
  },
  "expected-fail?": true,
  "description": "FoT token (5% tax): token-tax-reconciliation? fires on release because sub-held removes full AFA but record-released only accounts for net amount after tax. Conservation-of-funds also fires due to the accounting gap."
}
{
  "id": "scenarios/eq-v4-dominant-strategy-pass",
  "scenario-id": "eq-v4-dominant-strategy-pass",
  "title": "Dominant Strategy \u2014 PASS (adversarial events all rejected)",
  "description": "Adversarial buyer attempts unauthorized resolution and double-finalization; both are rejected. dominant-strategy-equilibrium returns :pass because attack-successes = 0 with attacks present.",
  "purpose": "regression",
  "schema-version": "1.1",
  "initial-block-time": 1000,
  "threat-tags": [
    "unauthorized-extraction"
  ],
  "agents": [
    {
      "id": "buyer",
      "address": "0xbuyer",
      "role": "buyer",
      "strategy": "adversarial"
    },
    {
      "id": "seller",
      "address": "0xseller",
      "role": "seller",
      "strategy": "honest"
    },
    {
      "id": "resolver",
      "address": "0xresolver",
      "role": "resolver",
      "strategy": "honest"
    }
  ],
  "theory": {
    "claim-id": "claims/eq-dominant-strategy-pass",
    "claim": "An adversarial buyer whose attacks are all rejected is trace-consistent with a dominant-strategy equilibrium (single-trace proxy).",
    "equilibrium-concept": [
      "dominant-strategy-equilibrium"
    ],
    "falsifies-if": [
      {
        "metric": "attack-successes",
        "op": ">",
        "value": 0
      },
      {
        "metric": "invariant-violations",
        "op": ">",
        "value": 0
      }
    ],
    "assumptions": []
  },
  "expectations": {
    "terminal": [
      {
        "path": [
          "live-states",
          0
        ],
        "equals": "released"
      }
    ],
    "metrics": [
      {
        "name": "attack-attempts",
        "op": ":>=",
        "value": 2
      },
      {
        "name": "attack-successes",
        "op": ":=",
        "value": 0
      },
      {
        "name": "rejected-attacks",
        "op": ":>=",
        "value": 2
      }
    ]
  },
  "events": [
    {
      "seq": 0,
      "time": 1000,
      "agent": "buyer",
      "action": "create_escrow",
      "params": {
        "token": "USDC",
        "to": "0xseller",
        "amount": 4000,
        "custom-resolver": "0xresolver"
      },
      "save-id-as": "wf0"
    },
    {
      "seq": 1,
      "time": 1060,
      "agent": "buyer",
      "action": "execute_resolution",
      "adversarial?": true,
      "params": {
        "workflow-id": "wf0",
        "is-release": true,
        "resolution-hash": "0xhack"
      }
    },
    {
      "seq": 2,
      "time": 1100,
      "agent": "buyer",
      "action": "release",
      "params": {
        "workflow-id": "wf0"
      }
    },
    {
      "seq": 3,
      "time": 1200,
      "agent": "buyer",
      "action": "release",
      "adversarial?": true,
      "params": {
        "workflow-id": "wf0"
      }
    }
  ]
}
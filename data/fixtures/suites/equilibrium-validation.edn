{:suite/id       :suites/equilibrium-validation
 :suite/title    "Trace-end mechanism-property and equilibrium-concept validation"
 :suite/purpose  "Verify that the equilibrium and mechanism-property validators fire correctly for a range of property types and scenario contexts. Scenarios 1–8 produce PASS or INCONCLUSIVE results. Scenarios 9–10 are negative test cases (purpose :theory-falsification) that are expected to produce mechanism/equilibrium :fail — confirming the validators detect violations. Scenarios 11–12 exercise the SPE heuristic: v11 produces :pass (no ex-post regret); v12 produces :fail (resolver slashed after strategic decision — ex-post regret detected)."
 :suite/prevents "Silent false-positives from :mechanism-properties and :equilibrium-concept fields being ignored or vacuously passing when required evidence is absent."
 :suite/class    :safety
 :suite/criticality :high

 :protocol   :protocol/baseline
 :state      :states/minimal-world
 :thresholds :thresholds/strict-baseline
 :traces [:traces/eq-v1-budget-balance-pass
          :traces/eq-v2-budget-balance-not-applicable
          :traces/eq-v3-dominant-strategy-inconclusive
          :traces/eq-v4-dominant-strategy-pass
          :traces/eq-v5-incentive-compat-inconclusive
          :traces/eq-v6-spe-always-inconclusive
          :traces/eq-v7-collusion-resistance-inconclusive
          :traces/eq-v8-individual-rationality-inconclusive
          ;; Negative cases — purpose :theory-falsification; expected to produce :fail
          :traces/eq-v9-nash-fail-attack-success
          :traces/eq-v10-incentive-compat-fail-attack-success
          ;; SPE heuristic: v11=:pass (honest, no slash); v12=:fail (slashed after decision)
          :traces/eq-v11-spe-pass-honest-resolver
          :traces/eq-v12-spe-fail-slashed-resolver]}

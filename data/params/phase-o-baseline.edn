{:scenario-id "phase-o-market-exit"
 :description "Phase O: Market Exit Cascade - baseline test scenario"
 :rng-seed 42
 
 :escrow-distribution
 {:type :lognormal
  :mean 10000
  :std 5000}
 
 :strategy-mix
 {:honest 0.50
  :lazy 0.15
  :malicious 0.25
  :collusive 0.10}
 
 :resolver-fee-bps 150
 :appeal-bond-bps 700
 :slash-multiplier 2.5
 :appeal-probability-if-correct 0.05
 :appeal-probability-if-wrong 0.40
 
 :slashing-detection-probability 0.10
 :fraud-detection-probability 0.25
 :fraud-slash-bps 5000
 :reversal-detection-probability 0.25
 :reversal-slash-bps 2500
 :timeout-slash-bps 200

 ;; Sequential escalation fraud model (matches baseline.edn :base band).
 ;; Without this, malicious resolvers have fsr=0.0 — honest retention is trivially stable.
 :fraud-model :sequential-escalation
 :escalation-assumption-band :base
 :p-appeal-wrong  0.40
 :p-l1-reversal   0.85
 :has-kleros?     true
 :p-l2-escalation 0.70
 :p-l2-reversal   0.95
 :fraud-success-rate 0.90  ; fallback for single-stage-ev compat
 
 :unstaking-delay-days 14
 :freeze-on-detection? true
 :freeze-duration-days 3
 :appeal-window-days 7
 
 :n-epochs 10
 :n-trials-per-epoch 500
 :n-resolvers 100
 :detection-decay-rate 0.0}

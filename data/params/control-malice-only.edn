{:description "Control baseline: Pure malicious (100% dishonest, no honest to compare)"
 :scenario-id "control-malice-only"
 :rng-seed 43

 :escrow-distribution
 {:type :lognormal
  :mean 10000
  :stddev 5000}

 :force-strategy :malicious
 :strategy-mix
 {:honest 0.0
  :lazy 0.0
  :malicious 1.0
  :collusive 0.0}

 :allow-slashing? true

 :resolver-fee-bps 150
 :appeal-bond-bps 700
 :slash-multiplier 2.5

 :appeal-probability-if-correct 0.05
 :appeal-probability-if-wrong 0.40
 :slashing-detection-probability 0.10

 :n-trials 1000
 :n-seeds 1
 :parallelism :auto
 :save-samples? false
 :save-sweep? false}
